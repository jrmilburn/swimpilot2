{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:migrate": "node -e \"require('dotenv').config({path:'.env.test'});process.env.DATABASE_URL=process.env.ADMIN_DATABASE_URL;require('child_process').execSync('prisma migrate deploy',{stdio:'inherit'})\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "~0.92.0",
    "@clerk/nextjs": "^7.2.7",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.105.1",
    "dotenv": "^17.4.2",
    "next": "^16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "svix": "^1.92.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
