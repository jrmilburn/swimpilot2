generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("ADMIN_DATABASE_URL")
}

enum Role {
  owner
  manager
  teacher
  front_desk

  @@map("role")
}

enum CommunicationPreference {
  email
  sms
  both

  @@map("communication_preference")
}

enum StudentStatus {
  active
  paused
  withdrawn

  @@map("student_status")
}

enum WeekDay {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday

  @@map("week_day")
}

enum ClassStatus {
  active
  cancelled

  @@map("class_status")
}

enum EnrolmentFrequency {
  weekly
  fortnightly_a
  fortnightly_b
  one_off

  @@map("enrolment_frequency")
}

enum EnrolmentStatus {
  active
  paused
  withdrawn

  @@map("enrolment_status")
}

enum ClassSessionStatus {
  scheduled
  cancelled
  completed

  @@map("class_session_status")
}

enum AttendanceStatus {
  present
  absent
  late

  @@map("attendance_status")
}

enum SkillStatus {
  not_introduced
  working_on
  achieved

  @@map("skill_status")
}

enum BillingFrequency {
  weekly
  fortnightly

  @@map("billing_frequency")
}

enum PaymentMethodType {
  card
  becs

  @@map("payment_method_type")
}

enum BillingProfileStatus {
  pending_setup
  active
  payment_failed
  cancelled

  @@map("billing_profile_status")
}

enum InvoiceStatus {
  draft
  issued
  paid
  overdue
  void

  @@map("invoice_status")
}

enum CreditSource {
  school_cancellation
  notified_absence
  refund
  manual

  @@map("credit_source")
}

enum CreditStatus {
  available
  applied
  expired
  void

  @@map("credit_status")
}

enum AiCallStatus {
  ok
  error

  @@map("ai_call_status")
}

enum OnboardingStep {
  profile
  locations
  levels
  skills
  classes
  teachers
  billing
  channels
  import
  done

  @@map("onboarding_step")
}

enum OnboardingStepStatus {
  not_started
  in_progress
  completed
  skipped

  @@map("onboarding_step_status")
}

enum PendingInvitationStatus {
  pending
  accepted
  revoked
  expired

  @@map("pending_invitation_status")
}

model School {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                String    @unique
  name                String
  timezone            String
  currency            String
  // Profile fields (Sprint 4 / Chunk 2). All nullable: a school can
  // skip the profile step legitimately, and the migration is safe on
  // pre-existing rows. `logoUrl` actually stores a Supabase Storage
  // path, not a resolvable URL — see docs/architecture.md "File storage".
  legalName           String?   @map("legal_name")
  tradingName         String?   @map("trading_name")
  abn                 String?
  gstRegistered       Boolean?  @map("gst_registered")
  primaryContactName  String?   @map("primary_contact_name")
  primaryContactEmail String?   @map("primary_contact_email")
  primaryContactPhone String?   @map("primary_contact_phone")
  logoUrl             String?   @map("logo_url")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy           String    @map("created_by") @db.Uuid
  updatedBy           String    @map("updated_by") @db.Uuid
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships   Membership[]
  locations     Location[]
  families      Family[]
  students      Student[]
  classLevels   ClassLevel[]
  classes       Class[]
  enrolments    Enrolment[]
  classSessions ClassSession[]
  attendance    Attendance[]
  skills        Skill[]
  studentSkills StudentSkill[]

  billingProfiles    BillingProfile[]
  invoices           Invoice[]
  invoiceLines       InvoiceLine[]
  credits            Credit[]
  billingCounter     BillingCounter?
  aiCalls            AiCall[]
  onboardingProgress OnboardingProgress?
  pendingInvitations PendingInvitation[]

  @@map("schools")
}

model User {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId   String?   @unique @map("clerk_id")
  email     String    @unique
  name      String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships         Membership[]
  taughtClasses       Class[]             @relation("ClassTeacher")
  taughtSessions      ClassSession[]      @relation("ClassSessionTeacher")
  invitedInvitations  PendingInvitation[] @relation("PendingInvitationInvitedBy")
  acceptedInvitations PendingInvitation[] @relation("PendingInvitationAccepted")

  @@map("users")
}

model Membership {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      Role
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([schoolId, userId])
  @@index([schoolId])
  @@index([userId])
  @@map("memberships")
}

model Location {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String    @map("school_id") @db.Uuid
  name        String
  timezone    String?
  addressLine String?   @map("address_line")
  suburb      String?
  state       String?
  postcode    String?
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String    @map("updated_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  school  School  @relation(fields: [schoolId], references: [id])
  classes Class[]

  @@index([schoolId])
  @@map("locations")
}

model Family {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId                String                  @map("school_id") @db.Uuid
  primaryContactName      String                  @map("primary_contact_name")
  primaryContactEmail     String                  @map("primary_contact_email")
  primaryContactPhone     String?                 @map("primary_contact_phone")
  addressLine1            String?                 @map("address_line_1")
  addressLine2            String?                 @map("address_line_2")
  suburb                  String?
  state                   String?
  postcode                String?
  communicationPreference CommunicationPreference @default(email) @map("communication_preference")
  notes                   String?
  createdAt               DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy               String                  @map("created_by") @db.Uuid
  updatedBy               String                  @map("updated_by") @db.Uuid
  deletedAt               DateTime?               @map("deleted_at") @db.Timestamptz(6)

  school         School          @relation(fields: [schoolId], references: [id])
  students       Student[]
  billingProfile BillingProfile?
  invoices       Invoice[]
  credits        Credit[]

  @@index([schoolId])
  @@index([schoolId, primaryContactEmail])
  @@map("families")
}

model Student {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String        @map("school_id") @db.Uuid
  familyId     String        @map("family_id") @db.Uuid
  firstName    String        @map("first_name")
  lastName     String        @map("last_name")
  dateOfBirth  DateTime      @map("date_of_birth") @db.Date
  medicalNotes String?       @map("medical_notes")
  photoUrl     String?       @map("photo_url")
  status       StudentStatus @default(active)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy    String        @map("created_by") @db.Uuid
  updatedBy    String        @map("updated_by") @db.Uuid
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)

  school        School         @relation(fields: [schoolId], references: [id])
  family        Family         @relation(fields: [familyId], references: [id])
  enrolments    Enrolment[]
  attendance    Attendance[]
  studentSkills StudentSkill[]
  invoiceLines  InvoiceLine[]
  credits       Credit[]

  @@index([schoolId])
  @@index([familyId])
  @@index([schoolId, familyId])
  @@map("students")
}

model ClassLevel {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId                    String    @map("school_id") @db.Uuid
  name                        String
  description                 String?
  ratio                       Int
  orderIndex                  Int       @map("order_index")
  minAgeMonths                Int?      @map("min_age_months")
  maxAgeMonths                Int?      @map("max_age_months")
  defaultProgressionThreshold Int       @default(80) @map("default_progression_threshold")
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy                   String    @map("created_by") @db.Uuid
  updatedBy                   String    @map("updated_by") @db.Uuid
  deletedAt                   DateTime? @map("deleted_at") @db.Timestamptz(6)

  school  School  @relation(fields: [schoolId], references: [id])
  classes Class[]
  skills  Skill[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("class_levels")
}

model Class {
  id                         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId                   String      @map("school_id") @db.Uuid
  locationId                 String      @map("location_id") @db.Uuid
  levelId                    String      @map("level_id") @db.Uuid
  teacherId                  String?     @map("teacher_id") @db.Uuid
  pendingTeacherInvitationId String?     @map("pending_teacher_invitation_id") @db.Uuid
  dayOfWeek                  WeekDay     @map("day_of_week")
  startTime                  DateTime    @map("start_time") @db.Time(0)
  durationMinutes            Int         @map("duration_minutes")
  capacity                   Int
  status                     ClassStatus @default(active)
  createdAt                  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy                  String      @map("created_by") @db.Uuid
  updatedBy                  String      @map("updated_by") @db.Uuid
  deletedAt                  DateTime?   @map("deleted_at") @db.Timestamptz(6)

  school                   School             @relation(fields: [schoolId], references: [id])
  location                 Location           @relation(fields: [locationId], references: [id])
  level                    ClassLevel         @relation(fields: [levelId], references: [id])
  teacher                  User?              @relation("ClassTeacher", fields: [teacherId], references: [id])
  pendingTeacherInvitation PendingInvitation? @relation(fields: [pendingTeacherInvitationId], references: [id])
  enrolments               Enrolment[]
  sessions                 ClassSession[]

  @@index([schoolId, locationId])
  @@index([schoolId, levelId])
  @@index([schoolId, teacherId])
  @@index([schoolId, pendingTeacherInvitationId])
  @@index([schoolId, dayOfWeek, startTime])
  @@map("classes")
}

model Enrolment {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String             @map("school_id") @db.Uuid
  studentId String             @map("student_id") @db.Uuid
  classId   String             @map("class_id") @db.Uuid
  frequency EnrolmentFrequency
  startDate DateTime           @map("start_date") @db.Date
  endDate   DateTime?          @map("end_date") @db.Date
  pauseFrom DateTime?          @map("pause_from") @db.Date
  pauseTo   DateTime?          @map("pause_to") @db.Date
  status    EnrolmentStatus    @default(active)
  notes     String?
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String             @map("created_by") @db.Uuid
  updatedBy String             @map("updated_by") @db.Uuid
  deletedAt DateTime?          @map("deleted_at") @db.Timestamptz(6)

  school       School        @relation(fields: [schoolId], references: [id])
  student      Student       @relation(fields: [studentId], references: [id])
  class        Class         @relation(fields: [classId], references: [id])
  attendance   Attendance[]
  invoiceLines InvoiceLine[]

  @@index([schoolId, studentId])
  @@index([schoolId, classId])
  @@index([schoolId, status])
  @@map("enrolments")
}

model ClassSession {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId           String             @map("school_id") @db.Uuid
  classId            String             @map("class_id") @db.Uuid
  sessionDate        DateTime           @map("session_date") @db.Date
  teacherId          String?            @map("teacher_id") @db.Uuid
  status             ClassSessionStatus @default(scheduled)
  cancellationReason String?            @map("cancellation_reason")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy          String             @map("created_by") @db.Uuid
  updatedBy          String             @map("updated_by") @db.Uuid
  deletedAt          DateTime?          @map("deleted_at") @db.Timestamptz(6)

  school     School       @relation(fields: [schoolId], references: [id])
  class      Class        @relation(fields: [classId], references: [id])
  teacher    User?        @relation("ClassSessionTeacher", fields: [teacherId], references: [id])
  attendance Attendance[]

  @@unique([classId, sessionDate])
  @@index([schoolId, sessionDate])
  @@index([schoolId, classId])
  @@map("class_sessions")
}

model Attendance {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String           @map("school_id") @db.Uuid
  classSessionId String           @map("class_session_id") @db.Uuid
  enrolmentId    String           @map("enrolment_id") @db.Uuid
  studentId      String           @map("student_id") @db.Uuid
  status         AttendanceStatus
  note           String?
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy      String           @map("created_by") @db.Uuid
  updatedBy      String           @map("updated_by") @db.Uuid
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz(6)

  school       School       @relation(fields: [schoolId], references: [id])
  classSession ClassSession @relation(fields: [classSessionId], references: [id])
  enrolment    Enrolment    @relation(fields: [enrolmentId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])

  @@unique([classSessionId, studentId])
  @@index([schoolId, classSessionId])
  @@index([schoolId, studentId])
  @@index([schoolId, enrolmentId])
  @@map("attendance")
}

model Skill {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String    @map("school_id") @db.Uuid
  levelId     String    @map("level_id") @db.Uuid
  name        String
  description String?
  orderIndex  Int       @map("order_index")
  isArchived  Boolean   @default(false) @map("is_archived")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String    @map("updated_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  school        School         @relation(fields: [schoolId], references: [id])
  level         ClassLevel     @relation(fields: [levelId], references: [id])
  studentSkills StudentSkill[]

  @@unique([schoolId, levelId, name])
  @@index([schoolId])
  @@index([levelId])
  @@index([schoolId, levelId, orderIndex])
  @@map("skills")
}

model StudentSkill {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String      @map("school_id") @db.Uuid
  studentId String      @map("student_id") @db.Uuid
  skillId   String      @map("skill_id") @db.Uuid
  status    SkillStatus @default(not_introduced)
  note      String?
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String      @map("created_by") @db.Uuid
  updatedBy String      @map("updated_by") @db.Uuid
  deletedAt DateTime?   @map("deleted_at") @db.Timestamptz(6)

  school  School  @relation(fields: [schoolId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  skill   Skill   @relation(fields: [skillId], references: [id])

  @@unique([studentId, skillId])
  @@index([schoolId])
  @@index([studentId])
  @@index([skillId])
  @@index([schoolId, studentId])
  @@index([schoolId, skillId])
  @@map("student_skills")
}

model BillingProfile {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId              String               @map("school_id") @db.Uuid
  familyId              String               @unique @map("family_id") @db.Uuid
  billingFrequency      BillingFrequency     @map("billing_frequency")
  billingAnchorDate     DateTime             @map("billing_anchor_date") @db.Date
  paymentMethodType     PaymentMethodType    @map("payment_method_type")
  stripeCustomerId      String?              @map("stripe_customer_id")
  stripePaymentMethodId String?              @map("stripe_payment_method_id")
  status                BillingProfileStatus @default(pending_setup)
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy             String               @map("created_by") @db.Uuid
  updatedBy             String               @map("updated_by") @db.Uuid
  deletedAt             DateTime?            @map("deleted_at") @db.Timestamptz(6)

  school School @relation(fields: [schoolId], references: [id])
  family Family @relation(fields: [familyId], references: [id])

  @@index([schoolId])
  @@index([schoolId, status])
  @@map("billing_profiles")
}

model Invoice {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId        String        @map("school_id") @db.Uuid
  familyId        String        @map("family_id") @db.Uuid
  invoiceNumber   String        @map("invoice_number")
  periodStart     DateTime      @map("period_start") @db.Date
  periodEnd       DateTime      @map("period_end") @db.Date
  subtotalCents   Int           @map("subtotal_cents")
  gstCents        Int           @map("gst_cents")
  totalCents      Int           @map("total_cents")
  status          InvoiceStatus @default(draft)
  issuedAt        DateTime?     @map("issued_at") @db.Timestamptz(6)
  paidAt          DateTime?     @map("paid_at") @db.Timestamptz(6)
  dueAt           DateTime?     @map("due_at") @db.Timestamptz(6)
  stripeInvoiceId String?       @map("stripe_invoice_id")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy       String        @map("created_by") @db.Uuid
  updatedBy       String        @map("updated_by") @db.Uuid
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(6)

  school         School        @relation(fields: [schoolId], references: [id])
  family         Family        @relation(fields: [familyId], references: [id])
  lines          InvoiceLine[]
  appliedCredits Credit[]

  @@unique([schoolId, invoiceNumber])
  @@index([schoolId])
  @@index([schoolId, familyId])
  @@index([schoolId, status, dueAt])
  @@index([schoolId, periodStart])
  @@map("invoices")
}

model InvoiceLine {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId         String    @map("school_id") @db.Uuid
  invoiceId        String    @map("invoice_id") @db.Uuid
  studentId        String    @map("student_id") @db.Uuid
  enrolmentId      String?   @map("enrolment_id") @db.Uuid
  description      String
  amountExGstCents Int       @map("amount_ex_gst_cents")
  gstAmountCents   Int       @map("gst_amount_cents")
  quantity         Int       @default(1)
  lineTotalCents   Int       @map("line_total_cents")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy        String    @map("created_by") @db.Uuid
  updatedBy        String    @map("updated_by") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  school    School     @relation(fields: [schoolId], references: [id])
  invoice   Invoice    @relation(fields: [invoiceId], references: [id])
  student   Student    @relation(fields: [studentId], references: [id])
  enrolment Enrolment? @relation(fields: [enrolmentId], references: [id])

  @@index([schoolId])
  @@index([invoiceId])
  @@index([schoolId, studentId])
  @@index([schoolId, enrolmentId])
  @@map("invoice_lines")
}

model Credit {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId           String       @map("school_id") @db.Uuid
  familyId           String       @map("family_id") @db.Uuid
  studentId          String?      @map("student_id") @db.Uuid
  amountCents        Int          @map("amount_cents")
  source             CreditSource
  expiresAt          DateTime?    @map("expires_at") @db.Timestamptz(6)
  status             CreditStatus @default(available)
  appliedToInvoiceId String?      @map("applied_to_invoice_id") @db.Uuid
  appliedAt          DateTime?    @map("applied_at") @db.Timestamptz(6)
  note               String?
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy          String       @map("created_by") @db.Uuid
  updatedBy          String       @map("updated_by") @db.Uuid
  deletedAt          DateTime?    @map("deleted_at") @db.Timestamptz(6)

  school           School   @relation(fields: [schoolId], references: [id])
  family           Family   @relation(fields: [familyId], references: [id])
  student          Student? @relation(fields: [studentId], references: [id])
  appliedToInvoice Invoice? @relation(fields: [appliedToInvoiceId], references: [id])

  @@index([schoolId])
  @@index([schoolId, familyId])
  @@index([schoolId, expiresAt])
  @@map("credits")
}

// One row per AI call made through `withAI`. Inputs are hashed, never
// stored — privacy-first per the Sprint 3 / Chunk 6 plan. user_id is not
// FK'd because we want log rows to survive user deletion.
model AiCall {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId      String       @map("school_id") @db.Uuid
  userId        String?      @map("user_id") @db.Uuid
  feature       String
  promptName    String       @map("prompt_name")
  promptVersion Int          @default(1) @map("prompt_version")
  model         String
  inputHash     String       @map("input_hash")
  inputTokens   Int?         @map("input_tokens")
  outputTokens  Int?         @map("output_tokens")
  latencyMs     Int          @map("latency_ms")
  status        AiCallStatus
  errorMessage  String?      @map("error_message")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy     String       @map("created_by") @db.Uuid
  updatedBy     String       @map("updated_by") @db.Uuid
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([schoolId, feature, createdAt(sort: Desc)])
  @@index([schoolId, userId])
  @@map("ai_calls")
}

// One row per school recording position in the onboarding wizard. The /
// landing redirect reads `current_step` / `completed_at` via the
// SECURITY DEFINER `app_get_onboarding_state` function before any tenant
// context is open. Materialised by an AFTER INSERT trigger on `schools`
// (see the 20260501130000_add_onboarding_progress migration); there is no
// app-side path that creates this row directly.
model OnboardingProgress {
  schoolId       String         @id @map("school_id") @db.Uuid
  currentStep    OnboardingStep @default(profile) @map("current_step")
  // JSONB keyed by OnboardingStep value (excluding `done`), valued by
  // OnboardingStepStatus. Repository owns parsing/validating the shape.
  stepStatuses   Json           @default("{}") @map("step_statuses")
  lastActivityAt DateTime       @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  completedAt    DateTime?      @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy      String         @map("created_by") @db.Uuid
  updatedBy      String         @map("updated_by") @db.Uuid
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz(6)

  school School @relation(fields: [schoolId], references: [id])

  @@map("onboarding_progress")
}

// Sprint 5 / Chunk 1: pending teacher invitations. Bridges the gap between
// "operator clicked Invite" and "invitee accepted and we have a real
// membership." A row's `status` evolves pending → (accepted | revoked |
// expired). The Teachers step renders pending rows alongside real teachers
// in the roster, and `Class.pendingTeacherInvitationId` lets a class
// "park" an assignment under a pending invite. The mutual-exclusion CHECK
// on `classes` ensures (teacher_id, pending_teacher_invitation_id) carry
// at most one non-null at a time.
model PendingInvitation {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId          String                  @map("school_id") @db.Uuid
  email             String
  role              Role
  clerkInvitationId String?                 @map("clerk_invitation_id")
  invitedByUserId   String                  @map("invited_by_user_id") @db.Uuid
  status            PendingInvitationStatus @default(pending)
  acceptedUserId    String?                 @map("accepted_user_id") @db.Uuid
  acceptedAt        DateTime?               @map("accepted_at") @db.Timestamptz(6)
  expiresAt         DateTime?               @map("expires_at") @db.Timestamptz(6)
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy         String                  @map("created_by") @db.Uuid
  updatedBy         String                  @map("updated_by") @db.Uuid
  deletedAt         DateTime?               @map("deleted_at") @db.Timestamptz(6)

  school       School  @relation(fields: [schoolId], references: [id])
  invitedBy    User    @relation("PendingInvitationInvitedBy", fields: [invitedByUserId], references: [id])
  acceptedUser User?   @relation("PendingInvitationAccepted", fields: [acceptedUserId], references: [id])
  classes      Class[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@map("pending_invitations")
}

// Per-school sequential counter used by Sprint 8 to allocate human-readable
// invoice_number values like "INV-000001". One row per school, mutated under
// SELECT … FOR UPDATE inside the invoice-creation transaction. Schema-only
// here — no app code reads or writes it this chunk.
model BillingCounter {
  schoolId          String   @id @map("school_id") @db.Uuid
  lastInvoiceNumber Int      @default(0) @map("last_invoice_number")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  school School @relation(fields: [schoolId], references: [id])

  @@map("billing_counters")
}
