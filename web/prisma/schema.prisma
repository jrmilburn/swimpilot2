generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("ADMIN_DATABASE_URL")
}

enum Role {
  owner
  manager
  teacher
  front_desk

  @@map("role")
}

enum CommunicationPreference {
  email
  sms
  both

  @@map("communication_preference")
}

enum StudentStatus {
  active
  paused
  withdrawn

  @@map("student_status")
}

model School {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String    @unique
  name      String
  timezone  String
  currency  String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships Membership[]
  locations   Location[]
  families    Family[]
  students    Student[]

  @@map("schools")
}

model User {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId   String?   @unique @map("clerk_id")
  email     String    @unique
  name      String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships Membership[]

  @@map("users")
}

model Membership {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      Role
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([schoolId, userId])
  @@index([schoolId])
  @@index([userId])
  @@map("memberships")
}

model Location {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  name      String
  timezone  String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("locations")
}

model Family {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId                String                  @map("school_id") @db.Uuid
  primaryContactName      String                  @map("primary_contact_name")
  primaryContactEmail     String                  @map("primary_contact_email")
  primaryContactPhone     String?                 @map("primary_contact_phone")
  addressLine1            String?                 @map("address_line_1")
  addressLine2            String?                 @map("address_line_2")
  suburb                  String?
  state                   String?
  postcode                String?
  communicationPreference CommunicationPreference @default(email) @map("communication_preference")
  notes                   String?
  createdAt               DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy               String                  @map("created_by") @db.Uuid
  updatedBy               String                  @map("updated_by") @db.Uuid
  deletedAt               DateTime?               @map("deleted_at") @db.Timestamptz(6)

  school   School    @relation(fields: [schoolId], references: [id])
  students Student[]

  @@index([schoolId])
  @@index([schoolId, primaryContactEmail])
  @@map("families")
}

model Student {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId      String        @map("school_id") @db.Uuid
  familyId      String        @map("family_id") @db.Uuid
  firstName     String        @map("first_name")
  lastName      String        @map("last_name")
  dateOfBirth   DateTime      @map("date_of_birth") @db.Date
  medicalNotes  String?       @map("medical_notes")
  photoUrl      String?       @map("photo_url")
  status        StudentStatus @default(active)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy     String        @map("created_by") @db.Uuid
  updatedBy     String        @map("updated_by") @db.Uuid
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz(6)

  school School @relation(fields: [schoolId], references: [id])
  family Family @relation(fields: [familyId], references: [id])

  @@index([schoolId])
  @@index([familyId])
  @@index([schoolId, familyId])
  @@map("students")
}
