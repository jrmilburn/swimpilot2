generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("ADMIN_DATABASE_URL")
}

enum Role {
  owner
  manager
  teacher
  front_desk

  @@map("role")
}

enum CommunicationPreference {
  email
  sms
  both

  @@map("communication_preference")
}

enum StudentStatus {
  active
  paused
  withdrawn

  @@map("student_status")
}

enum WeekDay {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday

  @@map("week_day")
}

enum ClassStatus {
  active
  cancelled

  @@map("class_status")
}

enum EnrolmentFrequency {
  weekly
  fortnightly_a
  fortnightly_b
  one_off

  @@map("enrolment_frequency")
}

enum EnrolmentStatus {
  active
  paused
  withdrawn

  @@map("enrolment_status")
}

enum ClassSessionStatus {
  scheduled
  cancelled
  completed

  @@map("class_session_status")
}

enum AttendanceStatus {
  present
  absent
  late

  @@map("attendance_status")
}

model School {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String    @unique
  name      String
  timezone  String
  currency  String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships    Membership[]
  locations      Location[]
  families       Family[]
  students       Student[]
  classLevels    ClassLevel[]
  classes        Class[]
  enrolments     Enrolment[]
  classSessions  ClassSession[]
  attendance     Attendance[]

  @@map("schools")
}

model User {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId   String?   @unique @map("clerk_id")
  email     String    @unique
  name      String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships    Membership[]
  taughtClasses  Class[]        @relation("ClassTeacher")
  taughtSessions ClassSession[] @relation("ClassSessionTeacher")

  @@map("users")
}

model Membership {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      Role
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([schoolId, userId])
  @@index([schoolId])
  @@index([userId])
  @@map("memberships")
}

model Location {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  name      String
  timezone  String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  school  School  @relation(fields: [schoolId], references: [id])
  classes Class[]

  @@index([schoolId])
  @@map("locations")
}

model Family {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId                String                  @map("school_id") @db.Uuid
  primaryContactName      String                  @map("primary_contact_name")
  primaryContactEmail     String                  @map("primary_contact_email")
  primaryContactPhone     String?                 @map("primary_contact_phone")
  addressLine1            String?                 @map("address_line_1")
  addressLine2            String?                 @map("address_line_2")
  suburb                  String?
  state                   String?
  postcode                String?
  communicationPreference CommunicationPreference @default(email) @map("communication_preference")
  notes                   String?
  createdAt               DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy               String                  @map("created_by") @db.Uuid
  updatedBy               String                  @map("updated_by") @db.Uuid
  deletedAt               DateTime?               @map("deleted_at") @db.Timestamptz(6)

  school   School    @relation(fields: [schoolId], references: [id])
  students Student[]

  @@index([schoolId])
  @@index([schoolId, primaryContactEmail])
  @@map("families")
}

model Student {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId      String        @map("school_id") @db.Uuid
  familyId      String        @map("family_id") @db.Uuid
  firstName     String        @map("first_name")
  lastName      String        @map("last_name")
  dateOfBirth   DateTime      @map("date_of_birth") @db.Date
  medicalNotes  String?       @map("medical_notes")
  photoUrl      String?       @map("photo_url")
  status        StudentStatus @default(active)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy     String        @map("created_by") @db.Uuid
  updatedBy     String        @map("updated_by") @db.Uuid
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz(6)

  school     School       @relation(fields: [schoolId], references: [id])
  family     Family       @relation(fields: [familyId], references: [id])
  enrolments Enrolment[]
  attendance Attendance[]

  @@index([schoolId])
  @@index([familyId])
  @@index([schoolId, familyId])
  @@map("students")
}

model ClassLevel {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId                    String    @map("school_id") @db.Uuid
  name                        String
  description                 String?
  ratio                       Int
  orderIndex                  Int       @map("order_index")
  minAgeMonths                Int?      @map("min_age_months")
  maxAgeMonths                Int?      @map("max_age_months")
  defaultProgressionThreshold Int       @default(80) @map("default_progression_threshold")
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy                   String    @map("created_by") @db.Uuid
  updatedBy                   String    @map("updated_by") @db.Uuid
  deletedAt                   DateTime? @map("deleted_at") @db.Timestamptz(6)

  school  School  @relation(fields: [schoolId], references: [id])
  classes Class[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("class_levels")
}

model Class {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId        String      @map("school_id") @db.Uuid
  locationId      String      @map("location_id") @db.Uuid
  levelId         String      @map("level_id") @db.Uuid
  teacherId       String?     @map("teacher_id") @db.Uuid
  dayOfWeek       WeekDay     @map("day_of_week")
  startTime       DateTime    @map("start_time") @db.Time(0)
  durationMinutes Int         @map("duration_minutes")
  capacity        Int
  status          ClassStatus @default(active)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy       String      @map("created_by") @db.Uuid
  updatedBy       String      @map("updated_by") @db.Uuid
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamptz(6)

  school     School         @relation(fields: [schoolId], references: [id])
  location   Location       @relation(fields: [locationId], references: [id])
  level      ClassLevel     @relation(fields: [levelId], references: [id])
  teacher    User?          @relation("ClassTeacher", fields: [teacherId], references: [id])
  enrolments Enrolment[]
  sessions   ClassSession[]

  @@index([schoolId, locationId])
  @@index([schoolId, levelId])
  @@index([schoolId, teacherId])
  @@index([schoolId, dayOfWeek, startTime])
  @@map("classes")
}

model Enrolment {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId   String              @map("school_id") @db.Uuid
  studentId  String              @map("student_id") @db.Uuid
  classId    String              @map("class_id") @db.Uuid
  frequency  EnrolmentFrequency
  startDate  DateTime            @map("start_date") @db.Date
  endDate    DateTime?           @map("end_date") @db.Date
  pauseFrom  DateTime?           @map("pause_from") @db.Date
  pauseTo    DateTime?           @map("pause_to") @db.Date
  status     EnrolmentStatus     @default(active)
  notes      String?
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy  String              @map("created_by") @db.Uuid
  updatedBy  String              @map("updated_by") @db.Uuid
  deletedAt  DateTime?           @map("deleted_at") @db.Timestamptz(6)

  school     School       @relation(fields: [schoolId], references: [id])
  student    Student      @relation(fields: [studentId], references: [id])
  class      Class        @relation(fields: [classId], references: [id])
  attendance Attendance[]

  @@index([schoolId, studentId])
  @@index([schoolId, classId])
  @@index([schoolId, status])
  @@map("enrolments")
}

model ClassSession {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId           String              @map("school_id") @db.Uuid
  classId            String              @map("class_id") @db.Uuid
  sessionDate        DateTime            @map("session_date") @db.Date
  teacherId          String?             @map("teacher_id") @db.Uuid
  status             ClassSessionStatus  @default(scheduled)
  cancellationReason String?             @map("cancellation_reason")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy          String              @map("created_by") @db.Uuid
  updatedBy          String              @map("updated_by") @db.Uuid
  deletedAt          DateTime?           @map("deleted_at") @db.Timestamptz(6)

  school     School       @relation(fields: [schoolId], references: [id])
  class      Class        @relation(fields: [classId], references: [id])
  teacher    User?        @relation("ClassSessionTeacher", fields: [teacherId], references: [id])
  attendance Attendance[]

  @@unique([classId, sessionDate])
  @@index([schoolId, sessionDate])
  @@index([schoolId, classId])
  @@map("class_sessions")
}

model Attendance {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId        String           @map("school_id") @db.Uuid
  classSessionId  String           @map("class_session_id") @db.Uuid
  enrolmentId     String           @map("enrolment_id") @db.Uuid
  studentId       String           @map("student_id") @db.Uuid
  status          AttendanceStatus
  note            String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy       String           @map("created_by") @db.Uuid
  updatedBy       String           @map("updated_by") @db.Uuid
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)

  school       School       @relation(fields: [schoolId], references: [id])
  classSession ClassSession @relation(fields: [classSessionId], references: [id])
  enrolment    Enrolment    @relation(fields: [enrolmentId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])

  @@unique([classSessionId, studentId])
  @@index([schoolId, classSessionId])
  @@index([schoolId, studentId])
  @@index([schoolId, enrolmentId])
  @@map("attendance")
}
